      "link": null,
      "locked": false,
      "text": "cards = {'1', '2', '3', '4', '5', '6', '7', '8', '9', '0'}\nchar cached[13^2]\n\nfor card in cards\n    for card2 in cards\n        hand = {card, card2}\n        if not hand in cached\n            append hand to cache\n\nprint(count of cache)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "cards = {'1', '2', '3', '4', '5', '6', '7', '8', '9', '0'}\nchar cached[13^2]\n\nfor card in cards\n    for card2 in cards\n        hand = {card, card2}\n        if not hand in cached\n            append hand to cache\n\nprint(count of cache)",
      "autoResize": true,
      "lineHeight": 1.25
    },
