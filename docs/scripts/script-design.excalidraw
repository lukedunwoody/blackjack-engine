      "link": null,
      "locked": false,
      "text": "function cache_or_bust\n    for each card in the hand\n        append card to new_hand\n        if new_total < 22\n            if !check_cache(new_hand, size + 1)\n                cache_add(hand)\n                cache_size++\n                cache_or_bust(new_hand, size + 1)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "function cache_or_bust\n    for each card in the hand\n        append card to new_hand\n        if new_total < 22\n            if !check_cache(new_hand, size + 1)\n                cache_add(hand)\n                cache_size++\n                cache_or_bust(new_hand, size + 1)",
      "autoResize": true,
      "lineHeight": 1.25
    },
