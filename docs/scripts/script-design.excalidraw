      "isDeleted": false,
      "boundElements": [],
      "updated": 1784695043656,
      "link": null,
      "locked": false,
      "text": "How to count the length of cache\n\ncurrent_pointer = cache_list_pointer\nint64 unique_states = 0\n\nwhile current_pointer != NULL\n    unqiue_states++\n    current_pointer = current_pointer->next\n\nprint(unique_states)\ngetchar()",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to count the length of cache\n\ncurrent_pointer = cache_list_pointer\nint64 unique_states = 0\n\nwhile current_pointer != NULL\n    unqiue_states++\n    current_pointer = current_pointer->next\n\nprint(unique_states)\ngetchar()",
      "autoResize": true,
      "lineHeight": 1.25
    },
