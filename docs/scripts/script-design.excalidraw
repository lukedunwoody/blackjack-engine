    {
      "id": "gZ5IuXSJYGp1HoxzRR8Qe",
      "type": "text",
      "x": 1411.8435393947786,
      "y": 1996.5267757231031,
      "width": 627,
      "height": 1200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6H",
      "roundness": null,
      "seed": 1586685463,
      "version": 1895,
      "versionNonce": 1184218233,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1784668146981,
      "link": null,
      "locked": false,
      "text": "struct hand {\n    int8 cards[24] // assumes sorted 24 bytes\n    int size // 4 bytes\n}\n\nstruct cache_entry {\n    hand hand\n    struct cache_entry *next // 1 byte\n} cache_entry\n\nappend_if_not_there(hand, pointer_to_start_of_list)\n    // We are assuming it comes in sorted\n\n    if pointer_to_start_of_lis\n\n    current_node = pointer_to_start_of_list\n    while (current_node.pointer != NULL) {\n        current_node = current_node.next\n\n        if is_hand_same(current_node.hand, hand) {\n            return\n        }\n    }\n\n    // If we get here, we know its a unique hand\n    new_hand = copy_hand(hand)\n    malloc size of cache_entry\n    cache_entry new_unique_hand\n    new_unqiue_hand.hand = new_hand\n    current_node.next = new_unqiue_hand\n\ncache_or_bust(hand, pointer_to_start_of_list)\n    // minimum hand length 2\n    if get_value(hand) > 21 {\n        return\n    }\n    append_if_not_there(hand, pointer_to_start_of_list)\n    for card in cards {\n        new_hand = copy_hand(hand)\n        sort_hand(new_hand)\n        cache_or_bust(new_hand, pointer_to_start_of_list)\n    \nmain()\n    cache_pointer = NULL\n    for i in cards\n        for j in cards\n            hand hand;\n            cache_or_bust()",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "struct hand {\n    int8 cards[24] // assumes sorted 24 bytes\n    int size // 4 bytes\n}\n\nstruct cache_entry {\n    hand hand\n    struct cache_entry *next // 1 byte\n} cache_entry\n\nappend_if_not_there(hand, pointer_to_start_of_list)\n    // We are assuming it comes in sorted\n\n    if pointer_to_start_of_lis\n\n    current_node = pointer_to_start_of_list\n    while (current_node.pointer != NULL) {\n        current_node = current_node.next\n\n        if is_hand_same(current_node.hand, hand) {\n            return\n        }\n    }\n\n    // If we get here, we know its a unique hand\n    new_hand = copy_hand(hand)\n    malloc size of cache_entry\n    cache_entry new_unique_hand\n    new_unqiue_hand.hand = new_hand\n    current_node.next = new_unqiue_hand\n\ncache_or_bust(hand, pointer_to_start_of_list)\n    // minimum hand length 2\n    if get_value(hand) > 21 {\n        return\n    }\n    append_if_not_there(hand, pointer_to_start_of_list)\n    for card in cards {\n        new_hand = copy_hand(hand)\n        sort_hand(new_hand)\n        cache_or_bust(new_hand, pointer_to_start_of_list)\n    \nmain()\n    cache_pointer = NULL\n    for i in cards\n        for j in cards\n            hand hand;\n            cache_or_bust()",
      "autoResize": true,
      "lineHeight": 1.25
    },
